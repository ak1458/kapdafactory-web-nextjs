# KapdaFactory Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# REQUIRED - Database
# ============================================
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# For Vercel Postgres, use the pooled connection URL
DATABASE_URL="postgresql://postgres:password@localhost:5432/kapdafactory"

# ============================================
# REQUIRED - Supabase API
# ============================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"

# ============================================
# REQUIRED - Authentication
# ============================================
# Generate a strong random string (32+ characters)
# Run: openssl rand -base64 32
AUTH_SECRET="your-super-secret-key-change-this-in-production"

# ============================================
# OPTIONAL - Image Storage (Vercel Blob)
# ============================================
# Only needed if you want to store images in Vercel Blob
# Get this from Vercel Dashboard > Storage > Blob
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxx"

# ============================================
# OPTIONAL - Email (for password reset)
# ============================================
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="noreply@kapdafactory.com"
# APP_URL="http://localhost:3000"

# ============================================
# OPTIONAL - Security
# ============================================
# Enable CSRF protection (disabled by default)
# ENABLE_CSRF="false"

# ============================================
# OPTIONAL - Development
# ============================================
# NODE_ENV="development"
